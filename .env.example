# Copiar a .env y ajustar. En produccion fija API key y MASTER KEY.

# Entorno de ARCA: homo (testing) | prod (produccion con validez fiscal)
ARCANUM_ENV=homo

# Clave de API que protege el gateway (header X-API-Key en cada request).
# Vacia => se genera al arrancar y se imprime UNA vez en el log.
# Generar:  openssl rand -hex 24
ARCANUM_API_KEY=

# Master key para cifrar las claves privadas de los certificados en la DB.
# OBLIGATORIA en produccion. Si la perdes, no se pueden descifrar los certificados.
# Generar:  openssl rand -hex 32
ARCANUM_MASTER_KEY=

# Postgres (usado por docker-compose). Si desplegas a mano, en su lugar podes
# definir DATABASE_URL directamente (postgres://user:pass@host:5432/db).
POSTGRES_USER=arcanum
POSTGRES_PASSWORD=arcanum
POSTGRES_DB=arcanum

# Puerto de escucha (por defecto 8094).
PORT=8094

# Usuario superadmin inicial (default "admin"). Solo aplica con la base vacia.
ARCANUM_ADMIN_USER=
# Contrasena del superadmin inicial (si se omite, se genera y se imprime en el log).
ARCANUM_ADMIN_PASS=

# Secreto para firmar las cookies de sesion (si se omite, deriva de la master key).
ARCANUM_SESSION_SECRET=

# Federacion opcional con Lockatus (OIDC). Si se dejan vacias, solo login local.
ARCANUM_OIDC_ISSUER=
ARCANUM_OIDC_CLIENT_ID=
ARCANUM_OIDC_CLIENT_SECRET=
# ARCANUM_OIDC_REDIRECT_URI=https://tu-dominio/api/auth/oidc/callback  (opcional; se deriva solo)

# Notificaciones por email (opcional). Si se omite el HOST, solo webhooks.
ARCANUM_SMTP_HOST=
ARCANUM_SMTP_PORT=587
ARCANUM_SMTP_USER=
ARCANUM_SMTP_PASS=
ARCANUM_SMTP_FROM=arcanum@tu-dominio
ARCANUM_NOTIFY_EMAIL=
